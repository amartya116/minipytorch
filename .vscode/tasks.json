{
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: cl.exe build active file",
			"command": "cl.exe",
			"args": [
				"/Zi",
				"/EHsc",
				"/nologo",
				"/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
				"${file}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$msCompile"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Task generated by Debugger."
		},
		{
			"label": "Build with pybind11",
			"type": "shell",
			"command": "cl.exe",
			"args": [
				"/Zi",
				"/EHsc",
				"/nologo",
				"/IC:/Users/amart/AppData/Local/Programs/Python/Python314/include",
				"/IC:/Users/amart/OneDrive/Desktop/projects/minipytorch/.venv/Lib/site-packages/pybind11/include",
				"/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
				"${file}"
			],
			"group": "build"
		},
		{
			"label": "Build with pybind11 and link",
			"type": "shell",
			"command": "cl.exe",
			"args": [
				"/Zi",
				"/EHsc",
				"/nologo",
				"/IC:/Users/amart/AppData/Local/Programs/Python/Python314/include",
				"/IC:/Users/amart/OneDrive/Desktop/projects/minipytorch/.venv/Lib/site-packages/pybind11/include",
				"/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
				"${file}",
				"/link",
				"/LIBPATH:C:/Users/amart/AppData/Local/Programs/Python/Python314/libs",
				"python314.lib"
			],
			"group": "build"
		}
	],
	"version": "2.0.0"
}